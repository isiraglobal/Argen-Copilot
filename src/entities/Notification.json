{
  "name": "Notification",
  "type": "object",
  "properties": {
    "user_email": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "message": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "info",
        "success",
        "warning",
        "announcement"
      ],
      "default": "info"
    },
    "read": {
      "type": "boolean",
      "default": false
    },
    "action_url": {
      "type": "string"
    },
    "sent_by": {
      "type": "string"
    },
    "is_broadcast": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "title",
    "message"
  ]
}