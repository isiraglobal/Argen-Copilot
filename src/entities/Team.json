{
  "name": "Team",
  "type": "object",
  "properties": {
    "company_name": {
      "type": "string"
    },
    "admin_email": {
      "type": "string"
    },
    "invite_code": {
      "type": "string"
    },
    "members": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "seat_limit": {
      "type": "number"
    },
    "subscription_status": {
      "type": "string",
      "enum": [
        "trial",
        "active",
        "cancelled",
        "expired"
      ],
      "default": "active"
    },
    "team_xp": {
      "type": "number",
      "default": 0
    },
    "custom_courses": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    }
  },
  "required": [
    "company_name",
    "admin_email",
    "invite_code"
  ]
}